{
  "name": "@interop/did-method-key",
  "description": "A did:key method resolver.",
  "version": "7.3.4",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run fix && pnpm run test-node && pnpm run test-browser",
    "test-browser": "playwright test",
    "test-node": "vitest run",
    "test-coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@digitalbazaar/x25519-key-agreement-key-2020": "^3.0.1",
    "@interop/data-integrity-core": "^8.3.0",
    "@interop/did-io": "^4.1.0",
    "@interop/ed25519-verification-key": "^8.0.3"
  },
  "devDependencies": {
    "@digitalbazaar/ecdsa-multikey": "^1.8.0",
    "@digitalbazaar/ed25519-multikey": "^1.3.1",
    "@digitalbazaar/x25519-key-agreement-key-2019": "^6.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=24.0"
  },
  "keywords": [
    "Decentralized",
    "Identifier",
    "DID"
  ],
  "packageManager": "pnpm@11.3.0",
  "author": {
    "name": "Interop Alliance",
    "url": "https://github.com/interop-alliance/"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/did-method-key.git"
  },
  "homepage": "https://github.com/interop-alliance/did-method-key",
  "bugs": "https://github.com/interop-alliance/did-method-key/issues"
}
